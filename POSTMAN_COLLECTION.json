{
  "info": {
    "_postman_id": "vortex-infrastructure-api",
    "name": "Vortex Infrastructure API",
    "description": "Multi-tenant Infrastructure Provisioning API for Kubernetes.\n\n## Overview\nProvisions and manages PostgreSQL databases and Redis caches dynamically in Kubernetes clusters with complete namespace isolation per project.\n\n## Authentication\nCurrently no authentication (development mode). Production deployment should add JWT/OAuth2.\n\n## Base URL\n`http://localhost:8080` (local Kind cluster)\n`http://infrastructure-api:8080` (inside Kubernetes cluster)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if the Infrastructure API is running and connected to the Kubernetes cluster."
          },
          "response": [
            {
              "name": "200 OK",
